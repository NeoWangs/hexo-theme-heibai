<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= page.title ? page.title + ' - ' : '' %><%= config.title %></title>
<meta name="description" content="<%= config.description || page.title || config.title %>">
<link rel="icon" href="<%- url_for('images/favicon-32x32.png') %>" sizes="32x32">
<link rel="icon" href="<%- url_for('images/favicon-16x16.png') %>" sizes="16x16">
<link rel="apple-touch-icon" href="<%- url_for('images/apple-touch-icon.png') %>">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;900&family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="<%- url_for('css/style.css') %>">
<% if (theme.mathjax) { %>
<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
<% } %>
<script>
(function () {
  try {
    var saved = localStorage.getItem('heibai-theme');
    var mode = saved || '<%= theme.default_theme || "light" %>';
    document.documentElement.setAttribute('data-theme', mode);
  } catch (e) {}
})();
</script>
