<footer class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__couplet">
      <% theme.footer.couplet.forEach(function (line, i) { %><span<%- i === theme.footer.couplet.length - 1 ? ' class="accent"' : '' %>><%= line %></span><% }) %>
    </div>
    <div class="site-footer__col">
      <div class="site-footer__col-label mono">朋友</div>
      <% theme.footer.links.forEach(function (link) { %>
      <a href="<%= link.url %>" target="_blank" rel="noopener"><%= link.name %> ↗</a>
      <% }) %>
    </div>
    <div class="site-footer__col">
      <div class="site-footer__col-label mono">账号</div>
      <% theme.footer.social.forEach(function (item) { %>
      <a href="<%= item.url %>" target="_blank" rel="noopener"><%= item.name %> ↗</a>
      <% }) %>
    </div>
    <div class="site-footer__col">
      <div class="site-footer__col-label mono">联系</div>
      <a class="mono" href="mailto:<%= theme.footer.contact_email %>"><%= theme.footer.contact_email %></a>
    </div>
  </div>
  <div class="site-footer__bottom">
    <span><%= theme.footer.copyright %></span>
    <a href="<%= theme.footer.beian.url %>" target="_blank" rel="noopener"><%= theme.footer.beian.text %></a>
  </div>
</footer>
